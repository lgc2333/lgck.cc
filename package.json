    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-format": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "unocss": "catalog:",
    "valaxy": "catalog:",
    "vite": "catalog:",
    "vite-plugin-vue-layouts-next": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "vue-tsc": "catalog:"
  }
}
