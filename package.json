{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "scripts": {
    "build:demo": "pnpm --dir demo build",
    "build:site": "pnpm --dir site build",
    "check": "vue-tsc -b --noEmit",
    "deploy:demo": "pnpm run build:demo && pnpm --dir demo deploy",
    "deploy:site": "pnpm run build:site && pnpm --dir site deploy",
    "deploy:workers": "pnpm run deploy:site && pnpm run deploy:demo",
    "format": "prettier -cw .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && pnpm run format"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
